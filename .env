# FreshGuard - Raspberry Pi Configuration
# Copy this to .env and fill in your password

# ── Database (Direct PostgreSQL connection) ───────────────────────────────────
# Replace [YOUR-PASSWORD] with your Supabase DB password
DATABASE_URL=connection string
# ── User Binding ──────────────────────────────────────────────────────────────
# The Supabase auth user UUID this device is linked to
# Find it in: Supabase Dashboard → Authentication → Users → copy the UUID
SUPABASE_USER_ID=db ID

SUPABASE_URL=supabase uri
SUPABASE_SERVICE_ROLE_KEY=service role key
